# ============================================================
# .gitignore — Escola da Saúde
# Projeto React + Node + Vite
# ============================================================

# ===========================
# Logs
# ===========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
firebase-debug.log*

# ===========================
# Dependências
# ===========================
node_modules/

# ===========================
# Ambiente / segredos
# ===========================
.env
.env.*
!.env.example
!.env.sample

# ===========================
# Build / Vite / SSR / Next
# ===========================
dist/
dist-ssr/
build/
.vite/
node_modules/.vite/
.next/
out/
.parcel-cache/
.sass-cache/

# ===========================
# IDE / Editor
# ===========================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace
.history/

# ===========================
# Cobertura de testes
# ===========================
coverage/
.nyc_output/
.vitest/
jest-coverage/
jest-cache/

# ===========================
# Caches e artefatos
# ===========================
.eslintcache
.stylelintcache
.cache/
.tmp/
temp/
tmp/
.turbo/
.pnp.*

.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ===========================
# Lockfiles — devem ser versionados
# ===========================
!package-lock.json
!yarn.lock
!pnpm-lock.yaml
!bun.lockb

# ===========================
# Armazenamento local da aplicação
# ===========================
data/
certificados/
uploads/
storage/
backups/

# ===========================
# Banco local / dumps
# ===========================
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.dump
*.sql.gz
*.backup

# ===========================
# Chaves / certificados / credenciais
# ===========================
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# ===========================
# Plataformas / deploy local
# ===========================
.vercel/
.render/
.neon/

# ===========================
# Sistema operacional
# ===========================
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini

# ===========================
# Ferramentas de testes
# ===========================
cypress/videos/
cypress/screenshots/
playwright-report/
test-results/
*.tap
jest-html-reporters-attach/

# ===========================
# Documentação / relatórios temporários
# ===========================
*.log.html
*.report.html
*.bak
*.orig
*.rej

# ===========================
# Temporários gerais
# ===========================
*.tmp
*.temp
*.swp

# ===========================
# Arquivos compactados locais
# ===========================
*.zip
*.rar
*.7z
*.tar
*.gz